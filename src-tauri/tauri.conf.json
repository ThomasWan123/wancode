{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wancode",
  "version": "0.16.0",
  "identifier": "com.wanwe.wancode",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WanCode",
        "width": 1100,
        "height": 760,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-src http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ThomasWan123/wancode/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1QjJERTI0RDBBQkI2MDEKUldRQnRxdlFKTjZ5ZFdxUDUyQVhXTUcxNlpRb05oZTMrTXZKWVRHNi9GeEwxWnRZc2xTVnRTYkMK"
    }
  }
}
